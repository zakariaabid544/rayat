MQTT_URL=mqtt://45.63.114.40:8080
MQTT_TOPIC="sensors/#"
STRIP_TOPIC_PREFIX=sensors/
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=rayat-mqtt-bridge
MQTT_RECONNECT_PERIOD_MS=5000
MQTT_CONNECT_TIMEOUT_MS=30000

API_URL=https://rayat.ma/api/sensors/update
API_TIMEOUT_MS=15000

# Se il tuo backend richiede un token Bearer, inseriscilo qui.
# Esempio:
# API_TOKEN=tuo_token_segreto
API_TOKEN=
API_TOKEN_HEADER=Authorization
API_TOKEN_PREFIX=Bearer

# In alternativa, se il backend usa una API key custom, usa queste due righe.
# Esempio:
# API_KEY=chiave_api
# API_KEY_HEADER=x-api-key
API_KEY=
API_KEY_HEADER=x-api-key
