# PostgreSQL (Render)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# JWT Secret (set a long random value before going live)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Server Configuration
PORT=3000
NODE_ENV=production

# MQTT Configuration (Optional)
# Modalita consigliata per lavorare senza Mac:
# - imposta MQTT_DIRECT_ENABLED=true
# - configura MQTT_BROKER / MQTT_TOPIC / credenziali broker
# - il backend ascoltera' direttamente il broker e salvera' i dati in autonomia
MQTT_DIRECT_ENABLED=false
MQTT_BROKER=mqtt://localhost:1883
MQTT_TOPIC="sensors/#"
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=
MQTT_RECONNECT_PERIOD_MS=5000
MQTT_CONNECT_TIMEOUT_MS=30000

# Bridge MQTT -> HTTP (optional)
# Se vuoi inoltrare i messaggi MQTT del VPS verso questo backend:
# - usa il bridge in backend/scripts/mqtt-http-bridge.js
# - pubblica idealmente topic del tipo sensors/<device_id>/<type>/<subtype>
# - oppure lascia vuoto device_id e il backend userà il device di default o il gateway auto-creato
MQTT_INGEST_TOKEN=
MQTT_INGEST_TOKEN_HEADER=x-rayat-bridge-token
MQTT_DEFAULT_DEVICE_ID=
MQTT_BRIDGE_DEVICE_ID=MQTT_BRIDGE_GATEWAY
MQTT_BRIDGE_DEVICE_API_KEY=
MQTT_BRIDGE_DEFAULT_USER_ID=

# CORS Configuration
CORS_ORIGIN=https://your-domain.com
APP_BASE_URL=https://your-domain.com
PUBLIC_APP_URL=https://your-domain.com
PASSWORD_RESET_URL=https://your-domain.com/reset-password
PASSWORD_RESET_EXPIRY_MINUTES=45
PASSWORD_RESET_RATE_LIMIT_MAX=5

# Mail transport configuration (preferred for password reset and admin registration notifications)
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-account@gmail.com
# SMTP_PASS=YOUR_16_CHAR_GMAIL_APP_PASSWORD
# SMTP_FROM="Rayat Notifications <your-account@gmail.com>"
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="Rayat Notifications <no-reply@your-domain.com>"

# Backward-compatible aliases for older notification config (optional if SMTP_* is set)
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Admin recipient for new public registrations
EMAIL_TO=zakariaabid544@gmail.com

# Missing data alert job
ALERT_JOB_CRON=* * * * *
ROUTER_INTERVAL_MINUTES=30
ROUTER_OFFLINE_GRACE_MINUTES=5
ROUTER_ALERT_EXTRA_MINUTES=15
ALERT_NOTIFICATION_COOLDOWN_MINUTES=60
ALERT_EMAILS=zakariaabid544@gmail.com
ALERT_PRIMARY_EMAIL=zakariaabid544@gmail.com
ALERT_FALLBACK_EMAIL=zakariaabid544@gmail.com

# Legacy compatibility only. Leave empty when using the ROUTER_* config above.
ALERT_EXPECTED_DATA_MINUTES=
ALERT_MISSING_DATA_THRESHOLD_MINUTES=

# Default Super Admin Credentials
ADMIN_DEFAULT_EMAIL=superadmin@your-domain.com
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_TO_A_STRONG_ADMIN_PASSWORD
