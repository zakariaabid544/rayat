# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rayat_db

# JWT Secret (set a long random value before going live)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Server Configuration
PORT=3000
NODE_ENV=production

# MQTT Configuration (Optional - for IoT devices)
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# CORS Configuration
CORS_ORIGIN=https://your-domain.com
APP_BASE_URL=https://your-domain.com
PUBLIC_APP_URL=https://your-domain.com
PASSWORD_RESET_URL=https://your-domain.com/reset-password
PASSWORD_RESET_EXPIRY_MINUTES=45
PASSWORD_RESET_RATE_LIMIT_MAX=5

# SMTP Configuration (Password Reset)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="Rayat Support <no-reply@your-domain.com>"

# Super Admin Credentials
SUPER_ADMIN_EMAIL=zakariaabid@hotmail.it
SUPER_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_ADMIN_PASSWORD
